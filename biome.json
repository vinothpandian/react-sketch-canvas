{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/coverage",
			"!**/playwright-report",
			"!**/test-results",
			"!**/apps/docs/.astro",
			"!**/packages/react-sketch-canvas/dist",
			"!**/packages/react-sketch-canvas/playwright-report",
			"!**/packages/react-sketch-canvas/test-results",
			"!**/apps/docs/src/content/docs/api"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
